# D'PARIS EGSOTIS Backend – Environment Variables
# Copy this file to .env and fill in your values

# App
APP_NAME="D'PARIS EGSOTIS API"
APP_VERSION="1.0.0"
DEBUG=true
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# Database (MySQL / MariaDB via XAMPP)
DATABASE_URL=mysql+pymysql://root:@localhost:3306/dparis_db

# JWT
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Admin credentials (used by create_admin.py script)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@dparis.id
ADMIN_PASSWORD=Admin@12345

# WhatsApp (CADAS Besemah)
WHATSAPP_NUMBER=6282XXXXXXXXX

# Google Maps API (optional, for GPS features)
GOOGLE_MAPS_API_KEY=

# File upload
UPLOAD_DIR=static/uploads
MAX_UPLOAD_SIZE_MB=5
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# CORS – comma-separated origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
